PORT=8080
LEAD_BOT_DB=data/lead_bot.sqlite3

APP_SECRET=replace-for-local-key-derivation
FERNET_KEY=

QUALIFIER_API_KEY=qualifier-dev-key
PRINCIPAL_API_KEY=principal-dev-key
PRINCIPAL_EMAIL=principal@example.com
CALENDAR_TIMEZONE=America/New_York

# Private owner login. Change these before exposing the app anywhere.
LEAD_BOT_USERNAME=owner
LEAD_BOT_PASSWORD=replace-with-a-long-private-password
LEAD_BOT_WEBHOOK_SECRET=replace-with-a-long-random-webhook-secret
LEAD_BOT_SESSION_SECONDS=43200
LEAD_BOT_COOKIE_SECURE=false

# Optional AI helper. If OPENAI_API_KEY is blank, the app uses a local helper.
OPENAI_API_KEY=
AI_MODEL=gpt-4.1-mini

# Docker/FastAPI stack.
DATABASE_URL=postgresql://postgres:postgres@db:5432/leads
REDIS_URL=redis://redis:6379/0
ENV=prod

# Social APIs.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=health-leads-bot/1.0
TWITTER_BEARER_TOKEN=

# Search and trends.
SERPAPI_KEY=
GOOGLE_TRENDS_GEO=US

# CRM.
HUBSPOT_API_KEY=

# Local dashboard provider settings can also be saved from the Automation panel.
# Use a private app access token for HubSpot where possible.
HUBSPOT_ACCESS_TOKEN=
CALENDAR_BOOKING_URL=
LICENSED_STATES=TX,NM,UT,CO,SD,NE,KS,MO,AR,LA,MS,AL,GA,FL,SC,NC,VA,WV,PA,OH,IN,KY,TN,IL,IA,MI,WI,OK,MD,DE,DC

# Email alerts.
ALERT_EMAIL_FROM=bot@example.com
ALERT_EMAIL_TO=you@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Optional comma-separated map: FL:Maria,TX:Devon,GA:Nina
STATE_OWNER_MAP=
